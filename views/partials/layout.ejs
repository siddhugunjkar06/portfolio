<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= settings.tagline || 'Professional Web Developer Portfolio' %>">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %><%= settings.siteName || 'DevPortfolio' %></title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>⚡</text></svg>">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <%- typeof extraCss !== 'undefined' ? extraCss : '' %>
</head>
<body>

<!-- Page Loader -->
<div class="page-loader">
  <div class="loader-logo"><%- settings.siteName || 'DevPortfolio' %></div>
  <div class="loader-bar"><div class="loader-progress"></div></div>
</div>

<!-- Custom Cursor -->
<div class="cursor-dot"></div>
<div class="cursor-ring"></div>

<!-- Navigation -->
<nav class="navbar">
  <div class="nav-container">
    <a href="/" class="nav-logo">
      <span><%= (settings.siteName || 'DevPortfolio').split(' ')[0] %></span>
      <span style="color:var(--text-secondary)"><%= (settings.siteName || 'DevPortfolio').split(' ').slice(1).join(' ') %></span>
      <span class="dot"></span>
    </a>
    <ul class="nav-links">
      <li><a href="/" class="<%= page === 'home' ? 'active' : '' %>">Home</a></li>
      <li><a href="/projects" class="<%= page === 'projects' ? 'active' : '' %>">Projects</a></li>
      <li><a href="/services" class="<%= page === 'services' ? 'active' : '' %>">Services</a></li>
      <li><a href="/blog" class="<%= page === 'blog' ? 'active' : '' %>">Blog</a></li>
      <li><a href="/contact" class="nav-cta <%= page === 'contact' ? 'active' : '' %>">Let's Talk</a></li>
    </ul>
    <button class="hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- Main Content -->
<main>
  <%- body %>
</main>

<!-- Footer -->
<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="footer-logo">
          <span><%= settings.siteName || 'DevPortfolio' %></span>
        </div>
        <p class="footer-desc"><%= settings.bio ? settings.bio.substring(0, 120) + '...' : 'Building digital experiences that drive business growth.' %></p>
        <div class="social-links">
          <% if(settings.github) { %><a href="<%= settings.github %>" target="_blank" class="social-link"><i class="fab fa-github"></i></a><% } %>
          <% if(settings.linkedin) { %><a href="<%= settings.linkedin %>" target="_blank" class="social-link"><i class="fab fa-linkedin-in"></i></a><% } %>
          <% if(settings.twitter) { %><a href="<%= settings.twitter %>" target="_blank" class="social-link"><i class="fab fa-twitter"></i></a><% } %>
          <a href="mailto:<%= settings.email || '' %>" class="social-link"><i class="fas fa-envelope"></i></a>
        </div>
      </div>
      <div class="footer-col">
        <h5>Navigation</h5>
        <ul class="footer-links">
          <li><a href="/">Home</a></li>
          <li><a href="/projects">Projects</a></li>
          <li><a href="/services">Services</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Services</h5>
        <ul class="footer-links">
          <li><a href="/services">Web Development</a></li>
          <li><a href="/services">E-Commerce</a></li>
          <li><a href="/services">Mobile Apps</a></li>
          <li><a href="/services">UI/UX Design</a></li>
          <li><a href="/services">Consulting</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Contact</h5>
        <ul class="footer-links">
          <li><a href="mailto:<%= settings.email %>"><i class="fas fa-envelope" style="margin-right:6px;color:var(--accent)"></i><%= settings.email || 'hello@portfolio.com' %></a></li>
          <li><a href="tel:<%= settings.phone %>"><i class="fas fa-phone" style="margin-right:6px;color:var(--accent)"></i><%= settings.phone || '+1 (555) 000-0000' %></a></li>
          <li style="color:var(--text-secondary);font-size:0.9rem"><i class="fas fa-map-pin" style="margin-right:6px;color:var(--accent)"></i><%= settings.location || 'San Francisco, CA' %></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; <%= new Date().getFullYear() %> <%= settings.siteName || 'DevPortfolio' %>. All rights reserved.</p>
      <p style="color:var(--text-muted)">Created by-© S Gunjkar</p>
    </div>
  </div>
</footer>

<script src="/js/main.js"></script>
<%- typeof extraJs !== 'undefined' ? extraJs : '' %>
</body>
</html>
