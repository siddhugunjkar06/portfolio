<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= settings.tagline || 'Professional Web Developer Portfolio' %>">
  <title><%= settings.siteName || 'DevPortfolio' %> — Web Developer</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>⚡</text></svg>">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<!-- Page Loader -->
<div class="page-loader" id="pageLoader">
  <div class="loader-logo"><%= settings.siteName || 'DevPortfolio' %></div>
  <div class="loader-bar"><div class="loader-progress"></div></div>
</div>

<!-- Custom Cursor -->
<div class="cursor-dot"></div>
<div class="cursor-ring"></div>

<!-- Navigation -->
<nav class="navbar" id="navbar">
  <div class="nav-container">
    <a href="/" class="nav-logo">
      <span><%= settings.siteName ? settings.siteName.split(' ')[0] : 'Dev' %></span>
      <span style="color:var(--ink-3)"><%= settings.siteName && settings.siteName.split(' ').length > 1 ? settings.siteName.split(' ').slice(1).join(' ') : 'Portfolio' %></span>
      <span class="dot"></span>
    </a>
    <ul class="nav-links" id="navLinks">
      <li><a href="/" class="active">Home</a></li>
      <li><a href="/projects">Projects</a></li>
      <li><a href="/services">Services</a></li>
      <li><a href="/blog">Blog</a></li>
      <li><a href="/contact" class="nav-cta">Let's Talk</a></li>
    </ul>
    <button class="hamburger" id="hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- ═══ HERO ═══ -->
<section class="hero">
  <div class="hero-bg">
    <div class="hero-grid"></div>
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>
  </div>
  <div class="hero-container">
    <div class="hero-content">
      <div class="hero-badge">
        <span class="blink"></span>
        Available for new projects
      </div>
      <h1 class="hero-title">
        I Build <em>Digital</em><br>Experiences That<br>Convert
      </h1>
      <p class="hero-desc">
        <%= settings.bio || 'Full-stack developer with 8+ years crafting scalable web applications and digital products that drive real business growth.' %>
      </p>
      <div class="hero-actions">
        <a href="/projects" class="btn btn-primary">
          <i class="fas fa-rocket"></i> View My Work
        </a>
        <a href="/contact" class="btn btn-secondary">
          <i class="fas fa-paper-plane"></i> Start a Project
        </a>
      </div>
      <div class="hero-stats">
        <div class="hero-stat">
          <h3><%= settings.yearsExperience || '8' %>+</h3>
          <p>Years Exp.</p>
        </div>
        <div class="hero-stat">
          <h3><%= settings.projectsCompleted || '120+' %></h3>
          <p>Projects</p>
        </div>
        <div class="hero-stat">
          <h3><%= settings.happyClients || '85+' %></h3>
          <p>Clients</p>
        </div>
      </div>
    </div>

    <!-- Code Preview Card -->
    <div class="hero-visual">
      <div class="hero-card">
        <div class="hero-card-header">
          <span class="hero-card-dot"></span>
          <span class="hero-card-dot"></span>
          <span class="hero-card-dot"></span>
          <span style="margin-left:auto;font-size:0.75rem;color:var(--ink-4)">portfolio.js</span>
        </div>
        <div class="code-block">
          <div><span class="cm">// Hello, World! 👋</span></div>
          <br>
          <div><span class="kw">const</span> <span class="fn">developer</span> = {</div>
          <div>&nbsp;&nbsp;<span class="obj">name</span>: <span class="str">"<%= settings.siteName || 'Alex Morgan' %>"</span>,</div>
          <div>&nbsp;&nbsp;<span class="obj">role</span>: <span class="str">"Full-Stack Dev"</span>,</div>
          <div>&nbsp;&nbsp;<span class="obj">skills</span>: [<span class="str">"React"</span>, <span class="str">"Node.js"</span>],</div>
          <div>&nbsp;&nbsp;<span class="obj">available</span>: <span class="num">true</span>,</div>
          <div>&nbsp;&nbsp;<span class="fn">hire</span>: () =&gt; <span class="str">"Let's build!"</span></div>
          <div>};</div>
          <br>
          <div><span class="fn">developer</span>.<span class="fn">hire</span>(); <span class="cm typing-cursor"></span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ STATS ═══ -->
<section class="stats-section">
  <div class="container">
    <div class="stats-grid">
      <div class="stat-item reveal">
        <h2><%= settings.yearsExperience || '8' %>+</h2>
        <p>Years of Excellence</p>
      </div>
      <div class="stat-item reveal reveal-delay-1">
        <h2><%= settings.projectsCompleted || '120+' %></h2>
        <p>Projects Delivered</p>
      </div>
      <div class="stat-item reveal reveal-delay-2">
        <h2><%= settings.happyClients || '85+' %></h2>
        <p>Happy Clients</p>
      </div>
      <div class="stat-item reveal reveal-delay-3">
        <h2><%= settings.awards || '12' %></h2>
        <p>Awards Won</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══ SERVICES ═══ -->
<section class="section" id="services">
  <div class="container">
    <div class="section-header reveal">
      <div class="section-eyebrow">What I Do</div>
      <h2 class="section-title">Services I <span class="gradient-text">Offer</span></h2>
      <p class="section-desc">From concept to deployment, I deliver complete digital solutions that help businesses grow.</p>
    </div>
    <div class="services-grid">
      <% services.forEach(function(s, i) { %>
      <div class="service-card reveal reveal-delay-<%= Math.min(i, 5) %>">
        <span class="service-icon"><%= s.icon %></span>
        <h3 class="service-title"><%= s.title %></h3>
        <p class="service-desc"><%= s.description %></p>
        <ul class="service-features">
          <% s.features.forEach(function(f) { %>
          <li><%= f %></li>
          <% }); %>
        </ul>
        <% if(s.price) { %><span class="service-price"><%= s.price %></span><% } %>
      </div>
      <% }); %>
    </div>
    <div style="text-align:center;margin-top:3rem" class="reveal">
      <a href="/services" class="btn btn-secondary">View All Services <i class="fas fa-arrow-right"></i></a>
    </div>
  </div>
</section>

<!-- ═══ FEATURED PROJECTS ═══ -->
<section class="section" style="background:var(--bg-alt)" id="projects">
  <div class="container">
    <div class="section-header reveal">
      <div class="section-eyebrow">My Work</div>
      <h2 class="section-title">Featured <span class="gradient-text">Projects</span></h2>
      <p class="section-desc">A selection showcasing my ability to build robust, scalable digital solutions.</p>
    </div>
    <div class="projects-grid">
      <% var catIcons = { web: '🌐', mobile: '📱', design: '🎨', ecommerce: '🛒', other: '⚡' }; %>
      <% featuredProjects.forEach(function(p, i) { %>
      <div class="project-card reveal reveal-delay-<%= Math.min(i, 5) %>" data-category="<%= p.category %>">
        <div class="project-img-placeholder">
          <% if(p.image) { %>
            <img src="<%= p.image %>" alt="<%= p.title %>" style="width:100%; height:100%; object-fit:cover;">
          <% } else { %>
            <%= catIcons[p.category] || '⚡' %>
          <% } %>
          <div class="project-img-overlay">
            <% if(p.liveUrl) { %>
            <a href="<%= p.liveUrl %>" target="_blank" class="btn btn-sm btn-primary"><i class="fas fa-external-link-alt"></i> Live</a>
            <% } %>
            <a href="/projects/<%= p._id %>" class="btn btn-sm btn-secondary">Details</a>
          </div>
        </div>
        <div class="project-body">
          <div class="project-category"><%= p.category %></div>
          <h3 class="project-title"><%= p.title %></h3>
          <p class="project-desc"><%= p.shortDesc %></p>
          <div class="tech-tags">
            <% p.technologies.slice(0,4).forEach(function(t) { %>
            <span class="tech-tag"><%= t %></span>
            <% }); %>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
    <div style="text-align:center;margin-top:3rem" class="reveal">
      <a href="/projects" class="btn btn-primary"><i class="fas fa-th"></i> View All Projects</a>
    </div>
  </div>
</section>

<!-- ═══ SKILLS ═══ -->
<section class="section" id="skills">
  <div class="container">
    <div class="section-header reveal">
      <div class="section-eyebrow">Expertise</div>
      <h2 class="section-title">My <span class="gradient-text">Tech Stack</span></h2>
      <p class="section-desc">Battle-tested technologies I use to build world-class digital products.</p>
    </div>
    <div class="skills-wrapper">
      <div>
        <% var currentCat = ''; %>
        <% skills.forEach(function(skill, i) { %>
          <% if(skill.category !== currentCat) { currentCat = skill.category; %>
          <div class="skills-category reveal"><%= skill.category.toUpperCase() %></div>
          <% } %>
          <div class="skill-item reveal">
            <div class="skill-header">
              <span class="skill-name"><%= skill.name %></span>
              <span class="skill-level"><%= skill.level %>%</span>
            </div>
            <div class="skill-bar">
              <div class="skill-fill" style="width:<%= skill.level %>%"></div>
            </div>
          </div>
        <% }); %>
      </div>
      <div class="reveal reveal-delay-2">
        <div style="background:white;border:1px solid var(--border);border-radius:var(--radius-lg);padding:2.5rem;position:sticky;top:90px">
          <h3 style="margin-bottom:1.5rem">Why Work With Me?</h3>
          <div style="display:flex;align-items:flex-start;gap:1rem;margin-bottom:1.2rem;padding-bottom:1.2rem;border-bottom:1px solid var(--border)">
            <div style="width:38px;height:38px;background:rgba(79,124,255,0.1);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0">⚡</div>
            <div><div style="font-weight:600;font-size:0.9rem;margin-bottom:0.2rem">Fast Delivery</div><div style="font-size:0.82rem;color:var(--ink-3)">Projects delivered on time, every time.</div></div>
          </div>
          <div style="display:flex;align-items:flex-start;gap:1rem;margin-bottom:1.2rem;padding-bottom:1.2rem;border-bottom:1px solid var(--border)">
            <div style="width:38px;height:38px;background:rgba(79,124,255,0.1);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0">🔒</div>
            <div><div style="font-weight:600;font-size:0.9rem;margin-bottom:0.2rem">Secure Code</div><div style="font-size:0.82rem;color:var(--ink-3)">Security-first development practices.</div></div>
          </div>
          <div style="display:flex;align-items:flex-start;gap:1rem;margin-bottom:1.2rem;padding-bottom:1.2rem;border-bottom:1px solid var(--border)">
            <div style="width:38px;height:38px;background:rgba(79,124,255,0.1);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0">📱</div>
            <div><div style="font-weight:600;font-size:0.9rem;margin-bottom:0.2rem">Mobile-First</div><div style="font-size:0.82rem;color:var(--ink-3)">Responsive on all screen sizes.</div></div>
          </div>
          <div style="display:flex;align-items:flex-start;gap:1rem;margin-bottom:1.2rem;padding-bottom:1.2rem;border-bottom:1px solid var(--border)">
            <div style="width:38px;height:38px;background:rgba(79,124,255,0.1);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0">🎯</div>
            <div><div style="font-weight:600;font-size:0.9rem;margin-bottom:0.2rem">Results Driven</div><div style="font-size:0.82rem;color:var(--ink-3)">Focused on measurable business outcomes.</div></div>
          </div>
          <div style="display:flex;align-items:flex-start;gap:1rem">
            <div style="width:38px;height:38px;background:rgba(79,124,255,0.1);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0">💬</div>
            <div><div style="font-weight:600;font-size:0.9rem;margin-bottom:0.2rem">Clear Communication</div><div style="font-size:0.82rem;color:var(--ink-3)">Regular updates throughout the project.</div></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ PROCESS ═══ -->
<section class="section" style="background:var(--bg-alt)">
  <div class="container">
    <div class="section-header reveal" style="text-align:center">
      <div class="section-eyebrow">How I Work</div>
      <h2 class="section-title">My <span class="gradient-text">Process</span></h2>
      <p class="section-desc" style="margin:0 auto">A structured approach ensuring quality delivery every time.</p>
    </div>
    <div class="process-steps">
      <div class="process-step reveal">
        <div class="process-number">01</div>
        <h3 style="font-size:1.1rem;margin-bottom:0.7rem">Discovery</h3>
        <p style="font-size:0.88rem">Deep dive into your goals, audience, and technical requirements.</p>
      </div>
      <div class="process-step reveal reveal-delay-1">
        <div class="process-number">02</div>
        <h3 style="font-size:1.1rem;margin-bottom:0.7rem">Design</h3>
        <p style="font-size:0.88rem">Wireframes and prototypes that prioritize UX and conversion.</p>
      </div>
      <div class="process-step reveal reveal-delay-2">
        <div class="process-number">03</div>
        <h3 style="font-size:1.1rem;margin-bottom:0.7rem">Develop</h3>
        <p style="font-size:0.88rem">Clean, scalable code with regular check-ins and updates.</p>
      </div>
      <div class="process-step reveal reveal-delay-3">
        <div class="process-number">04</div>
        <h3 style="font-size:1.1rem;margin-bottom:0.7rem">Deploy</h3>
        <p style="font-size:0.88rem">Rigorous testing, optimized launch, and ongoing support.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══ TESTIMONIALS ═══ -->
<section class="section" id="testimonials">
  <div class="container">
    <div class="section-header reveal" style="text-align:center">
      <div class="section-eyebrow">Client Love</div>
      <h2 class="section-title">What Clients <span class="gradient-text">Say</span></h2>
    </div>
    <div class="testimonials-slider reveal">
      <div class="testimonials-track">
        <% testimonials.forEach(function(t) { %>
        <div class="testimonial-card">
          <div class="testimonial-stars">
            <% for(var s = 0; s < (t.rating || 5); s++) { %>★<% } %>
          </div>
          <p class="testimonial-text"><%= t.message %></p>
          <div class="testimonial-author">
            <div class="author-avatar">
              <%= t.name.charAt(0) %><%= t.name.split(' ')[1] ? t.name.split(' ')[1].charAt(0) : '' %>
            </div>
            <div>
              <div class="author-name"><%= t.name %></div>
              <div class="author-role"><%= t.role %><%= t.company ? ' @ ' + t.company : '' %></div>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
    <div class="slider-controls">
      <button class="slider-btn slider-prev" aria-label="Previous"><i class="fas fa-arrow-left"></i></button>
      <div class="slider-dots">
        <% testimonials.forEach(function(t, i) { %>
        <button class="slider-dot <%= i === 0 ? 'active' : '' %>" aria-label="Slide <%= i+1 %>"></button>
        <% }); %>
      </div>
      <button class="slider-btn slider-next" aria-label="Next"><i class="fas fa-arrow-right"></i></button>
    </div>
  </div>
</section>

<!-- ═══ CTA ═══ -->
<section class="section" style="background:var(--bg-alt)">
  <div class="container" style="text-align:center">
    <div class="reveal">
      <div style="display:inline-block;background:rgba(79,124,255,0.08);border:1px solid rgba(79,124,255,0.2);border-radius:100px;padding:0.4rem 1.2rem;font-size:0.8rem;color:var(--accent);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:1.5rem">
        🟢 Currently Available
      </div>
      <h2 style="margin-bottom:1rem">Ready to Build Something<br><span class="gradient-text">Amazing?</span></h2>
      <p style="font-size:1.05rem;color:var(--ink-3);margin-bottom:2.5rem;max-width:500px;margin-left:auto;margin-right:auto">
        Let's turn your vision into reality. I'm taking on new projects and would love to hear about yours.
      </p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
        <a href="/contact" class="btn btn-primary btn-lg"><i class="fas fa-rocket"></i> Start Your Project</a>
        <a href="mailto:<%= settings.email || 'hello@portfolio.com' %>" class="btn btn-secondary btn-lg"><i class="fas fa-envelope"></i> Send Email</a>
      </div>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="footer-logo"><span><%= settings.siteName || 'DevPortfolio' %></span></div>
        <p class="footer-desc"><%= settings.bio ? settings.bio.substring(0, 120) + '...' : 'Building digital experiences that drive business growth.' %></p>
        <div class="social-links">
          <% if(settings.github) { %><a href="<%= settings.github %>" target="_blank" class="social-link"><i class="fab fa-github"></i></a><% } %>
          <% if(settings.linkedin) { %><a href="<%= settings.linkedin %>" target="_blank" class="social-link"><i class="fab fa-linkedin-in"></i></a><% } %>
          <% if(settings.twitter) { %><a href="<%= settings.twitter %>" target="_blank" class="social-link"><i class="fab fa-twitter"></i></a><% } %>
          <a href="mailto:<%= settings.email || '' %>" class="social-link"><i class="fas fa-envelope"></i></a>
        </div>
      </div>
      <div class="footer-col">
        <h5>Navigation</h5>
        <ul class="footer-links">
          <li><a href="/">Home</a></li>
          <li><a href="/projects">Projects</a></li>
          <li><a href="/services">Services</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Services</h5>
        <ul class="footer-links">
          <li><a href="/services">Web Development</a></li>
          <li><a href="/services">E-Commerce</a></li>
          <li><a href="/services">Mobile Apps</a></li>
          <li><a href="/services">UI/UX Design</a></li>
          <li><a href="/services">Consulting</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Contact</h5>
        <ul class="footer-links">
          <% if(settings.email) { %><li><a href="mailto:<%= settings.email %>"><i class="fas fa-envelope" style="margin-right:6px;color:var(--accent)"></i><%= settings.email %></a></li><% } %>
          <% if(settings.phone) { %><li><a href="tel:<%= settings.phone %>"><i class="fas fa-phone" style="margin-right:6px;color:var(--accent)"></i><%= settings.phone %></a></li><% } %>
          <li style="color:var(--ink-3);font-size:0.9rem"><i class="fas fa-map-pin" style="margin-right:6px;color:var(--accent)"></i><%= settings.location || 'San Francisco, CA' %></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; <%= new Date().getFullYear() %> <%= settings.siteName || 'DevPortfolio' %>. All rights reserved.</p>
      <p style="color:var(--ink-4)">Built with ❤️ &amp; Node.js</p>
    </div>
  </div>
</footer>

<script src="/js/main.js"></script>
</body>
</html>
