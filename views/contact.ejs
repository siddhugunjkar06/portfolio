<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Get in touch with SG Developer for web development, mobile apps, UI/UX design, and digital consulting services.">
  <meta name="keywords" content="contact, web developer, hire developer, digital services">
  <meta name="author" content="<%= settings.siteName || 'SG Developer' %>">
  <meta name="robots" content="index, follow">
  <meta name="theme-color" content="#000000">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>Contact — <%= settings.siteName || 'DevPortfolio' %></title>
  <link rel="canonical" href="https://sgdeveloper.onrender.com/contact">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  
  <%- include('partials/structured-data') %>
</head>
<body>
<div class="cursor-dot"></div>
<div class="cursor-ring"></div>

<nav class="navbar" id="navbar">
  <div class="nav-container">
    <a href="/" class="nav-logo">
      <span><%= settings.siteName ? settings.siteName.split(' ')[0] : 'Dev' %></span>
      <span style="color:var(--ink-3)"><%= settings.siteName && settings.siteName.split(' ').length > 1 ? settings.siteName.split(' ').slice(1).join(' ') : 'Portfolio' %></span>
      <span class="dot"></span>
    </a>
    <ul class="nav-links" id="navLinks">
      <li><a href="/">Home</a></li>
      <li><a href="/projects">Projects</a></li>
      <li><a href="/services">Services</a></li>
      <li><a href="/blog">Blog</a></li>
      <li><a href="/contact" class="nav-cta active">Let's Talk</a></li>
    </ul>
    <button class="hamburger" id="hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
  </div>
</nav>

<section class="page-header">
  <div class="container">
    <div class="section-eyebrow">Get In Touch</div>
    <h1>Let's Build <span class="gradient-text">Something</span></h1>
    <p style="color:var(--ink-3);font-size:1.05rem;max-width:500px;margin-top:0.5rem">
      Have a project in mind? I'd love to hear about it. Let's discuss how we can work together.
    </p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="contact-wrapper">
      <div>
        <h3 style="margin-bottom:1.5rem">Contact Information</h3>
        <div class="contact-info-item">
          <div class="contact-icon"><i class="fa-solid fa-envelope"></i></div>
          <div class="contact-detail">
            <p>Email</p>
            <p><%= settings.email || 'hello@portfolio.com' %></p>
          </div>
        </div>
        <div class="contact-info-item">
          <div class="contact-icon"><i class="fa-solid fa-phone"></i></div>
          <div class="contact-detail">
            <p>Phone</p>
            <p><%= settings.phone || '+1 (555) 000-0000' %></p>
          </div>
        </div>
        <div class="contact-info-item">
          <div class="contact-icon"><i class="fa-solid fa-location-dot"></i></div>
          <div class="contact-detail">
            <p>Location</p>
            <p><%= settings.location || 'San Francisco, CA' %></p>
          </div>
        </div>
        <div class="contact-info-item">
          <div class="contact-icon"><i class="fa-solid fa-clock"></i></i></div>
          <div class="contact-detail">
            <p>Response Time</p>
            <p>Within 24 hours</p>
          </div>
        </div>
        <div class="social-links" style="margin-top:2rem">
          <% if(settings.github) { %><a href="<%= settings.github %>" target="_blank" class="social-link"><i class="fab fa-github"></i></a><% } %>
          <% if(settings.linkedin) { %><a href="<%= settings.linkedin %>" target="_blank" class="social-link"><i class="fab fa-linkedin-in"></i></a><% } %>
          <% if(settings.instagram) { %><a href="<%= settings.instagram %>" target="_blank" class="social-link"><i class="fab fa-instagram"></i></a><% } %>
          <a href="https://wa.me/<%= settings.phone %>" target="_blank" class="social-link"><i class="fa-brands fa-whatsapp"></i></a>
        </div>
        <div style="margin-top:2.5rem;padding:1.5rem;background:rgba(0,229,160,0.06);border:1px solid rgba(0,229,160,0.15);border-radius:var(--radius-sm)">
          <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.5rem">
            <span style="width:8px;height:8px;background:var(--accent2);border-radius:50%;animation:pulse 2s infinite"></span>
            <span style="color:var(--accent2);font-size:0.85rem;font-weight:600">Currently Available</span>
          </div>
          <p style="font-size:0.88rem;color:var(--ink-3)">Open to new projects. Let's discuss your ideas.</p>
        </div>
      </div>

      <div>
        <div style="background:white;border:1px solid var(--border);border-radius:var(--radius-lg);padding:2.5rem">
          <h3 style="margin-bottom:1.5rem">Send a Message</h3>
          <form id="contact-form" novalidate>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Your Name *</label>
                <input name="name" type="text" class="form-control" placeholder="John Smith" required>
              </div>
              <div class="form-group">
                <label class="form-label">Email Address *</label>
                <input name="email" type="email" class="form-control" placeholder="john@company.com" required>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Subject *</label>
                <input name="subject" type="text" class="form-control" placeholder="Project Inquiry" required>
              </div>
              <div class="form-group">
                <label class="form-label">Budget Range</label>
                <select name="budget" class="form-control form-select">
                  <option value="">Select budget...</option>
                  <option value="< ₹1k">Less than ₹1,000</option>
                  <option value="₹1k-₹5k">₹1,000 – ₹5,000</option>
                  <option value="₹5k-₹15k">₹5,000 – ₹15,000</option>
                  <option value="₹15k-₹50k">₹15,000 – ₹50,000</option>
                  <option value="₹50k+">₹50,000+</option>
                </select>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Message *</label>
              <textarea name="message" class="form-control" rows="6" placeholder="Tell me about your project, goals, timeline..." required></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%">
              <i class="fas fa-paper-plane"></i> Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer', { settings }) %>
<script src="/js/main.js"></script>
</body>
</html>
