<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= project.description || 'View the details of this project including technologies used, features, and deliverables.' %>">
  <meta name="keywords" content="<%= project.title %>, project, portfolio, web development">
  <meta name="author" content="<%= settings.siteName || 'SG Developer' %>">
  <meta name="robots" content="index, follow">
  <meta name="theme-color" content="#000000">
  <title><%= project.title %> — <%= settings.siteName || 'DevPortfolio' %></title>
  <link rel="canonical" href="https://sgdeveloper.onrender.com/projects/<%= project._id %>">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  
  <%- include('partials/structured-data') %>
</head>
<body>
<div class="cursor-dot"></div>
<div class="cursor-ring"></div>
<%- include('partials/navbar', { settings, page: 'projects' }) %>

<section class="page-header">
  <div class="container">
    <a href="/projects" style="display:inline-flex;align-items:center;gap:0.5rem;color:var(--ink-4);font-size:0.9rem;margin-bottom:1.5rem;transition:color 0.2s" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--ink-4)'">
      <i class="fas fa-arrow-left"></i> Back to Projects
    </a>
    <div style="font-size:0.78rem;color:var(--accent);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.8rem"><%= project.category %></div>
    <h1><%= project.title %></h1>
    <p style="color:var(--ink-3);margin-top:0.5rem;font-size:1.05rem;max-width:600px"><%= project.shortDesc %></p>
    <div style="display:flex;gap:1rem;margin-top:1.5rem;flex-wrap:wrap">
      <% if(project.liveUrl) { %>
      <a href="<%= project.liveUrl %>" target="_blank" class="btn btn-primary"><i class="fas fa-external-link-alt"></i> View Live</a>
      <% } %>
      <% if(project.githubUrl) { %>
      <a href="<%= project.githubUrl %>" target="_blank" class="btn btn-secondary"><i class="fab fa-github"></i> Source Code</a>
      <% } %>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 320px;gap:3rem;align-items:start">
      <div>
        <% var catIcons = { web: '🌐', mobile: '📱', design: '🎨', ecommerce: '🛒', other: '⚡' }; %>
        <div style="background:linear-gradient(135deg,rgba(79,124,255,0.08),rgba(0,229,160,0.05));border:1px solid var(--border);border-radius:var(--radius-lg);height:340px;display:flex;align-items:center;justify-content:center;font-size:8rem;margin-bottom:3rem;overflow:hidden">
          <% if(project.image) { %>
            <img src="<%= project.image %>" alt="<%= project.title %>" style="width:100%; height:100%; object-fit:cover;">
          <% } else { %>
            <%= catIcons[project.category] || '⚡' %>
          <% } %>
        </div>

        <div class="reveal">
          <h2 style="font-size:1.5rem;margin-bottom:1.2rem">About This Project</h2>
          <p style="color:var(--ink-3);line-height:1.9;font-size:1rem"><%= project.description %></p>
        </div>

        <div class="reveal" style="margin-top:2.5rem">
          <h2 style="font-size:1.5rem;margin-bottom:1.2rem">Technologies Used</h2>
          <div class="tech-tags">
            <% project.technologies.forEach(function(t) { %>
            <span class="tech-tag" style="padding:0.4rem 1rem;font-size:0.85rem"><%= t %></span>
            <% }); %>
          </div>
        </div>
      </div>

      <div style="position:sticky;top:90px">
        <div style="background:white;border:1px solid var(--border);border-radius:var(--radius);padding:1.8rem;margin-bottom:1.5rem">
          <h3 style="font-size:1rem;margin-bottom:1.2rem;padding-bottom:0.8rem;border-bottom:1px solid var(--border)">Project Details</h3>
          <div style="display:flex;flex-direction:column;gap:0.9rem">
            <div style="display:flex;justify-content:space-between">
              <span style="font-size:0.82rem;color:var(--ink-4)">Category</span>
              <span style="font-size:0.85rem;font-weight:500;text-transform:capitalize"><%= project.category %></span>
            </div>
            <div style="display:flex;justify-content:space-between">
              <span style="font-size:0.82rem;color:var(--ink-4)">Status</span>
              <span class="status-badge status-<%= project.status %>"><%= project.status %></span>
            </div>
            <div style="display:flex;justify-content:space-between">
              <span style="font-size:0.82rem;color:var(--ink-4)">Year</span>
              <span style="font-size:0.85rem"><%= new Date(project.createdAt).getFullYear() %></span>
            </div>
          </div>
        </div>
        <div style="background:rgba(79,124,255,0.06);border:1px solid rgba(79,124,255,0.15);border-radius:var(--radius);padding:1.8rem">
          <h3 style="font-size:1rem;margin-bottom:0.8rem">Interested in a similar project?</h3>
          <p style="font-size:0.85rem;color:var(--ink-3);margin-bottom:1.2rem">Let's discuss your idea and build something amazing.</p>
          <a href="/contact" class="btn btn-primary" style="width:100%;justify-content:center">
            <i class="fas fa-rocket"></i> Start a Project
          </a>
        </div>
      </div>
    </div>

    <% var others = relatedProjects.filter(function(r){ return r._id.toString() !== project._id.toString(); }).slice(0,3); %>
    <% if(others.length > 0) { %>
    <div style="margin-top:5rem">
      <h2 style="margin-bottom:2rem">Other Projects</h2>
      <div class="grid-3">
        <% others.forEach(function(r) { %>
        <a href="/projects/<%= r._id %>" class="card" style="padding:0;display:block;text-decoration:none;overflow:hidden">
          <div style="height:180px;background:linear-gradient(135deg,rgba(79,124,255,0.08),rgba(0,229,160,0.05));display:flex;align-items:center;justify-content:center;font-size:3rem;overflow:hidden">
            <% if(r.image) { %>
              <img src="<%= r.image %>" alt="<%= r.title %>" style="width:100%; height:100%; object-fit:cover;">
            <% } else { %>
              <%= catIcons[r.category] || '⚡' %>
            <% } %>
          </div>
          <div style="padding:1.5rem">
            <div style="font-size:0.75rem;color:var(--accent);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.4rem"><%= r.category %></div>
            <h3 style="font-size:1rem;margin-bottom:0.4rem"><%= r.title %></h3>
            <p style="font-size:0.85rem;color:var(--ink-3)"><%= r.shortDesc %></p>
          </div>
        </a>
        <% }); %>
      </div>
    </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer', { settings }) %>
<script src="/js/main.js"></script>
</body>
</html>
