<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error — Portfolio</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<section style="min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center">
  <div>
    <div style="font-size:5rem;margin-bottom:1rem">⚠️</div>
    <h1 style="font-size:2rem;margin-bottom:0.5rem">Something Went Wrong</h1>
    <p style="color:var(--text-secondary);margin-bottom:2rem"><%= typeof message !== 'undefined' ? message : 'An unexpected error occurred.' %></p>
    <a href="/" class="btn btn-primary"><i class="fas fa-home"></i> Back to Home</a>
  </div>
</section>
</body>
</html>
