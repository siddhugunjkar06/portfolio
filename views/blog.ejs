<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Blog — <%= settings.siteName || 'DevPortfolio' %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="cursor-dot"></div>
<div class="cursor-ring"></div>
<%- include('partials/navbar', { settings, page: 'blog' }) %>

<section class="page-header">
  <div class="container">
    <div class="section-eyebrow">Blog</div>
    <h1>Thoughts &amp; <span class="gradient-text">Insights</span></h1>
    <p style="color:var(--ink-3);margin-top:0.5rem;max-width:500px">
      Articles on web development, design patterns, and building products that matter.
    </p>
  </div>
</section>

<section class="section">
  <div class="container">
    <% if(posts && posts.length > 0) { %>
    <div class="grid-3">
      <% posts.forEach(function(post, i) { %>
      <div class="card reveal reveal-delay-<%= Math.min(i % 3, 5) %>" style="padding:2rem;display:flex;flex-direction:column;gap:1rem">
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.5rem">
          <span style="font-size:0.78rem;color:var(--ink-4)"><%= new Date(post.createdAt).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' }) %></span>
          <span style="font-size:0.78rem;color:var(--accent)"><i class="fas fa-eye" style="margin-right:4px"></i><%= post.views || 0 %> views</span>
        </div>
        <h3 style="font-size:1.2rem;line-height:1.3"><%= post.title %></h3>
        <p style="font-size:0.9rem;color:var(--ink-3);display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden"><%= post.excerpt %></p>
        <div class="tech-tags">
          <% post.tags.forEach(function(tag) { %>
          <span class="tech-tag"><%= tag %></span>
          <% }); %>
        </div>
        <a href="/blog/<%= post.slug %>" class="btn btn-sm btn-secondary" style="align-self:flex-start">
          Read More <i class="fas fa-arrow-right"></i>
        </a>
      </div>
      <% }); %>
    </div>
    <% } else { %>
    <div style="text-align:center;padding:5rem 2rem">
      <div style="font-size:4rem;margin-bottom:1rem">📝</div>
      <h3 style="margin-bottom:0.5rem">No Posts Yet</h3>
      <p style="color:var(--ink-4)">Check back soon for articles on web development, design, and tech.</p>
    </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer', { settings }) %>
<script src="/js/main.js"></script>
</body>
</html>
