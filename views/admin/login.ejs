<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login — Portfolio</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="admin-login-page">
  <div class="login-orb login-orb-1"></div>
  <div class="login-orb login-orb-2"></div>

  <div class="login-card">
    <div class="login-logo">
      <div class="login-logo-text">⚡ Portfolio</div>
    </div>

    <h2 class="login-title">Welcome Back</h2>
    <p class="login-sub">Sign in to manage your portfolio content</p>

    <% if(error && error.length > 0) { %>
      <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error[0] %></div>
    <% } %>
    <% if(success && success.length > 0) { %>
      <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success[0] %></div>
    <% } %>

    <form method="POST" action="/admin/login">
      <div class="admin-form-group">
        <label class="admin-label">Email Address</label>
        <div style="position:relative">
          <i class="fas fa-envelope" style="position:absolute;left:14px;top:50%;transform:translateY(-50%);color:var(--text-muted);font-size:0.9rem"></i>
          <input type="email" name="email" class="admin-input" style="padding-left:2.8rem" placeholder="admin@portfolio.com" required autocomplete="email">
        </div>
      </div>
      <div class="admin-form-group">
        <label class="admin-label">Password</label>
        <div style="position:relative">
          <i class="fas fa-lock" style="position:absolute;left:14px;top:50%;transform:translateY(-50%);color:var(--text-muted);font-size:0.9rem"></i>
          <input type="password" name="password" id="passwordInput" class="admin-input" style="padding-left:2.8rem;padding-right:2.8rem" placeholder="••••••••" required autocomplete="current-password">
          <button type="button" onclick="togglePass()" style="position:absolute;right:14px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:0.9rem">
            <i class="fas fa-eye" id="eyeIcon"></i>
          </button>
        </div>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:0.5rem;padding:1rem">
        <i class="fas fa-sign-in-alt"></i> Sign In
      </button>
    </form>

    <div style="margin-top:1.5rem;padding:1rem;background:rgba(79,124,255,0.06);border:1px solid rgba(79,124,255,0.15);border-radius:8px;font-size:0.8rem;color:var(--text-muted)">
      <strong style="color:var(--text-secondary)">Demo Credentials:</strong><br>
      Email: admin@portfolio.com<br>
      Password: Admin@123456
    </div>

    <div style="text-align:center;margin-top:1.5rem">
      <a href="/" style="font-size:0.85rem;color:var(--text-muted);transition:color 0.2s" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-muted)'">
        <i class="fas fa-arrow-left" style="margin-right:5px"></i> Back to Portfolio
      </a>
    </div>
  </div>
</div>
<script>
function togglePass() {
  const input = document.getElementById('passwordInput');
  const icon = document.getElementById('eyeIcon');
  if (input.type === 'password') {
    input.type = 'text';
    icon.className = 'fas fa-eye-slash';
  } else {
    input.type = 'password';
    icon.className = 'fas fa-eye';
  }
}
</script>
</body>
</html>
