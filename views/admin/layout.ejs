<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' — ' : '' %>Admin Panel</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>⚙️</text></svg>">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link href="https://api.fontshare.com/v2/css?f[]=clash-display@400,500,600,700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="admin-layout">

  <!-- Sidebar -->
  <aside class="admin-sidebar" id="adminSidebar">
    <div class="sidebar-header">
      <div class="sidebar-logo">⚡ AdminPanel</div>
      <div class="sidebar-subtitle">Portfolio Management</div>
    </div>

    <nav class="sidebar-nav">
      <div class="nav-section-label">Overview</div>
      <a href="/admin/dashboard" class="sidebar-link <%= page === 'dashboard' ? 'active' : '' %>">
        <span class="icon"><i class="fas fa-chart-line"></i></span> Dashboard
        <% if(typeof stats !== 'undefined' && stats.unreadContacts > 0) { %>
          <span class="badge"><%= stats.unreadContacts %></span>
        <% } %>
      </a>

      <div class="nav-section-label">Content</div>
      <a href="/admin/projects" class="sidebar-link <%= page === 'projects' ? 'active' : '' %>">
        <span class="icon"><i class="fas fa-folder-open"></i></span> Projects
      </a>
      <a href="/admin/services" class="sidebar-link <%= page === 'services' ? 'active' : '' %>">
        <span class="icon"><i class="fas fa-cogs"></i></span> Services
      </a>
      <a href="/admin/testimonials" class="sidebar-link <%= page === 'testimonials' ? 'active' : '' %>">
        <span class="icon"><i class="fas fa-star"></i></span> Testimonials
      </a>
      <a href="/admin/skills" class="sidebar-link <%= page === 'skills' ? 'active' : '' %>">
        <span class="icon"><i class="fas fa-code"></i></span> Skills
      </a>
      <a href="/admin/blog" class="sidebar-link <%= page === 'blog' ? 'active' : '' %>">
        <span class="icon"><i class="fas fa-pen-nib"></i></span> Blog Posts
      </a>

      <div class="nav-section-label">Communication</div>
      <a href="/admin/contacts" class="sidebar-link <%= page === 'contacts' ? 'active' : '' %>">
        <span class="icon"><i class="fas fa-inbox"></i></span> Messages
      </a>

      <div class="nav-section-label">System</div>
      <a href="/admin/settings" class="sidebar-link <%= page === 'settings' ? 'active' : '' %>">
        <span class="icon"><i class="fas fa-sliders-h"></i></span> Settings
      </a>
      <a href="/" target="_blank" class="sidebar-link">
        <span class="icon"><i class="fas fa-external-link-alt"></i></span> View Site
      </a>
    </nav>

    <div class="sidebar-footer">
      <div class="admin-user">
        <div class="admin-avatar"><%= (adminName || 'A').charAt(0).toUpperCase() %></div>
        <div>
          <div class="admin-name"><%= adminName || 'Admin' %></div>
          <div class="admin-role">Administrator</div>
        </div>
      </div>
      <a href="/admin/logout" class="logout-btn">
        <i class="fas fa-sign-out-alt"></i> Sign Out
      </a>
    </div>
  </aside>

  <!-- Main Content -->
  <div class="admin-main">
    <header class="admin-topbar">
      <div style="display:flex;align-items:center;gap:1rem">
        <button class="sidebar-toggle" style="background:none;border:none;color:var(--text-primary);font-size:1.1rem;cursor:pointer;padding:4px;display:none" id="sidebarToggle">
          <i class="fas fa-bars"></i>
        </button>
        <span class="topbar-title"><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Dashboard' %></span>
      </div>
      <div class="topbar-right">
        <a href="/admin/contacts?status=unread" class="topbar-notification" title="Unread Messages">
          <i class="fas fa-bell"></i>
          <% if(typeof stats !== 'undefined' && stats.unreadContacts > 0) { %>
            <span class="notification-dot"></span>
          <% } %>
        </a>
        <a href="/" target="_blank" class="topbar-notification" title="View Site">
          <i class="fas fa-globe"></i>
        </a>
      </div>
    </header>

    <main class="admin-content">
      <% if(success && success.length > 0) { %>
        <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success[0] %></div>
      <% } %>
      <% if(error && error.length > 0) { %>
        <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error[0] %></div>
      <% } %>
      <%- body %>
    </main>
  </div>
</div>

<script src="/js/admin.js"></script>
<script>
  // Mobile sidebar toggle
  const toggleBtn = document.getElementById('sidebarToggle');
  const sidebar = document.getElementById('adminSidebar');
  if (toggleBtn) {
    toggleBtn.style.display = 'block';
    toggleBtn.addEventListener('click', () => sidebar.classList.toggle('open'));
  }
</script>
</body>
</html>
