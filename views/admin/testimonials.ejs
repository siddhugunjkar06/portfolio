<%- include('head', { pageTitle: 'Testimonials' }) %>
<%- include('sidebar', { page, stats: {}, adminName }) %>
<div class="admin-main">
  <%- include('topbar', { pageTitle: 'Testimonials', stats: {} }) %>
  <main class="admin-content">
    <%- include('alerts') %>

    <div style="margin-bottom:1.5rem">
      <h2 style="font-family:'Clash Display',sans-serif;font-size:1.4rem;margin-bottom:0.2rem">Testimonials</h2>
      <p style="font-size:0.85rem;color:var(--text-muted)"><%= testimonials.length %> client testimonials</p>
    </div>

    <div class="admin-grid-2">
      <div class="admin-form-card" style="align-self:start">
        <div class="admin-form-title"><i class="fas fa-plus" style="margin-right:8px;color:var(--accent)"></i>Add Testimonial</div>
        <form method="POST" action="/admin/testimonials" enctype="multipart/form-data">
          <div class="admin-form-row">
            <div class="admin-form-group">
              <label class="admin-label">Client Name *</label>
              <input type="text" name="name" class="admin-input" placeholder="Jane Doe" required>
            </div>
            <div class="admin-form-group">
              <label class="admin-label">Role *</label>
              <input type="text" name="role" class="admin-input" placeholder="CTO" required>
            </div>
          </div>
          <div class="admin-form-row">
            <div class="admin-form-group">
              <label class="admin-label">Company</label>
              <input type="text" name="company" class="admin-input" placeholder="Acme Inc">
            </div>
            <div class="admin-form-group">
              <label class="admin-label">Rating</label>
              <select name="rating" class="admin-input" style="cursor:pointer">
                <option value="5">★★★★★  5 stars</option>
                <option value="4">★★★★☆  4 stars</option>
                <option value="3">★★★☆☆  3 stars</option>
              </select>
            </div>
          </div>
          <div class="admin-form-group">
            <label class="admin-label">Testimonial *</label>
            <textarea name="message" class="admin-input" rows="4" placeholder="What the client said..." required maxlength="500"></textarea>
          </div>
          <div class="admin-form-row">
            <div class="admin-form-group">
              <label class="admin-label">Display Order</label>
              <input type="number" name="order" class="admin-input" value="0" min="0">
            </div>
            <div class="admin-form-group" style="display:flex;align-items:flex-end;padding-bottom:0.1rem">
              <div class="switch-wrapper">
                <label class="switch">
                  <input type="checkbox" name="featured" checked>
                  <span class="switch-slider"></span>
                </label>
                <span class="admin-label" style="margin-bottom:0">Featured</span>
              </div>
            </div>
          </div>
          <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-plus"></i> Add Testimonial</button>
        </form>
      </div>

      <div class="admin-card" style="max-height:620px;overflow-y:auto">
        <div class="admin-card-header">
          <span class="admin-card-title">All Testimonials</span>
        </div>
        <% if(testimonials && testimonials.length > 0) { %>
          <% testimonials.forEach(function(t) { %>
          <%
            var tName    = t.name    || 'Unknown';
            var tRole    = t.role    || '';
            var tCompany = t.company || '';
            var tMessage = t.message || '';
            var tRating  = t.rating  || 5;
          %>
          <div style="padding:1.2rem;border-bottom:1px solid var(--border)">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:0.5rem">
              <div style="flex:1">
                <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.3rem;flex-wrap:wrap">
                  <span style="font-weight:600;font-size:0.9rem;color:var(--text-primary)"><%= tName %></span>
                  <span style="font-size:0.75rem;color:var(--text-muted)"><%= tRole %><%= tCompany ? ' @ '+tCompany : '' %></span>
                </div>
                <div style="color:#FFD700;font-size:0.85rem;margin-bottom:0.4rem">
                  <% for(var s=0;s<tRating;s++){ %>★<% } %>
                </div>
                <p style="font-size:0.82rem;color:var(--text-secondary);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden"><%= tMessage %></p>
              </div>
              <form method="POST" action="/admin/testimonials/<%= t._id %>?_method=DELETE" class="delete-form">
                <button type="submit" class="action-btn danger"><i class="fas fa-trash"></i></button>
              </form>
            </div>
          </div>
          <% }); %>
        <% } else { %>
          <div style="padding:2rem;text-align:center;color:var(--text-muted)">No testimonials yet.</div>
        <% } %>
      </div>
    </div>

  </main>
</div>
<%- include('foot') %>
