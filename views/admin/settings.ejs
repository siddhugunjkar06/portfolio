<%- include('head', { pageTitle: 'Settings' }) %>
<%- include('sidebar', { page, stats: {}, adminName }) %>
<div class="admin-main">
  <%- include('topbar', { pageTitle: 'Settings', stats: {} }) %>
  <main class="admin-content">
    <%- include('alerts') %>

    <div style="margin-bottom:1.5rem">
      <h2 style="font-family:'Clash Display',sans-serif;font-size:1.4rem;margin-bottom:0.2rem">Site Settings</h2>
      <p style="font-size:0.85rem;color:var(--text-muted)">Manage your portfolio information and preferences</p>
    </div>

    <div class="admin-grid-2">
      <!-- General Settings -->
      <div class="admin-form-card">
        <div class="admin-form-title"><i class="fas fa-globe" style="margin-right:8px;color:var(--accent)"></i>General Information</div>
        <form method="POST" action="/admin/settings">
          <div class="admin-form-group">
            <label class="admin-label">Site / Brand Name</label>
            <input type="text" name="siteName" class="admin-input" value="<%= settings.siteName || '' %>" placeholder="Alex Morgan Dev">
          </div>
          <div class="admin-form-group">
            <label class="admin-label">Tagline</label>
            <input type="text" name="tagline" class="admin-input" value="<%= settings.tagline || '' %>" placeholder="Crafting Digital Experiences">
          </div>
          <div class="admin-form-group">
            <label class="admin-label">Bio / About</label>
            <textarea name="bio" class="admin-input" rows="4" placeholder="Tell visitors about yourself..." maxlength="500"><%= settings.bio || '' %></textarea>
          </div>
          <div class="admin-form-row">
            <div class="admin-form-group">
              <label class="admin-label">Email Address</label>
              <input type="email" name="email" class="admin-input" value="<%= settings.email || '' %>" placeholder="hello@portfolio.com">
            </div>
            <div class="admin-form-group">
              <label class="admin-label">Phone Number</label>
              <input type="text" name="phone" class="admin-input" value="<%= settings.phone || '' %>" placeholder="+1 (555) 000-0000">
            </div>
          </div>
          <div class="admin-form-group">
            <label class="admin-label">Location</label>
            <input type="text" name="location" class="admin-input" value="<%= settings.location || '' %>" placeholder="San Francisco, CA">
          </div>
          <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-save"></i> Save General</button>
        </form>
      </div>

      <div>
        <!-- Social Links -->
        <div class="admin-form-card" style="margin-bottom:1.5rem">
          <div class="admin-form-title"><i class="fas fa-share-alt" style="margin-right:8px;color:var(--accent)"></i>Social Media</div>
          <form method="POST" action="/admin/settings">
            <div class="admin-form-group">
              <label class="admin-label"><i class="fab fa-github" style="margin-right:6px"></i>GitHub URL</label>
              <input type="url" name="github" class="admin-input" value="<%= settings.github || '' %>" placeholder="https://github.com/username">
            </div>
            <div class="admin-form-group">
              <label class="admin-label"><i class="fab fa-linkedin" style="margin-right:6px"></i>LinkedIn URL</label>
              <input type="url" name="linkedin" class="admin-input" value="<%= settings.linkedin || '' %>" placeholder="https://linkedin.com/in/username">
            </div>
            <div class="admin-form-group">
              <label class="admin-label"><i class="fab fa-instagram" style="margin-right:6px"></i>Instagram URL</label>
              <input type="url" name="instagram" class="admin-input" value="<%= settings.instagram || '' %>" placeholder="https://instagram.com/username">
            </div>
            <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-save"></i> Save Links</button>
          </form>
        </div>

        <!-- Hero Stats -->
        <div class="admin-form-card" style="margin-bottom:1.5rem">
          <div class="admin-form-title"><i class="fas fa-chart-bar" style="margin-right:8px;color:var(--accent)"></i>Hero Statistics</div>
          <form method="POST" action="/admin/settings">
            <div class="admin-form-row">
              <div class="admin-form-group">
                <label class="admin-label">Years Experience</label>
                <input type="text" name="yearsExperience" class="admin-input" value="<%= settings.yearsExperience || '8' %>" placeholder="8">
              </div>
              <div class="admin-form-group">
                <label class="admin-label">Projects Completed</label>
                <input type="text" name="projectsCompleted" class="admin-input" value="<%= settings.projectsCompleted || '120+' %>" placeholder="120+">
              </div>
            </div>
            <div class="admin-form-row">
              <div class="admin-form-group">
                <label class="admin-label">Happy Clients</label>
                <input type="text" name="happyClients" class="admin-input" value="<%= settings.happyClients || '85+' %>" placeholder="85+">
              </div>
              <div class="admin-form-group">
                <label class="admin-label">Awards Won</label>
                <input type="text" name="awards" class="admin-input" value="<%= settings.awards || '12' %>" placeholder="12">
              </div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-save"></i> Save Stats</button>
          </form>
        </div>

        <!-- Change Password -->
        <div class="admin-form-card">
          <div class="admin-form-title"><i class="fas fa-lock" style="margin-right:8px;color:#FF3B30"></i>Change Password</div>
          <form method="POST" action="/admin/change-password">
            <div class="admin-form-group">
              <label class="admin-label">Current Password</label>
              <input type="password" name="currentPassword" class="admin-input" placeholder="••••••••" required>
            </div>
            <div class="admin-form-group">
              <label class="admin-label">New Password</label>
              <input type="password" name="newPassword" class="admin-input" placeholder="Min. 8 characters" required minlength="8">
            </div>
            <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-key"></i> Update Password</button>
          </form>
        </div>
      </div>
    </div>

  </main>
</div>
<%- include('foot') %>
